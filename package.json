{
  "name": "coursera-manual-runner",
  "version": "1.0.0",
  "private": true,
  "description": "Manual-assisted Coursera CSV runner for Ubuntu.",
  "scripts": {
    "start": "node coursera_manual_runner.js",
    "auto": "MODE=auto node coursera_manual_runner.js",
    "auto:headless": "MODE=auto HEADLESS=y node coursera_manual_runner.js",
    "auto:verbose": "MODE=auto OBSERVE_VERBOSE=y node coursera_manual_runner.js",
    "diagnose": "MODE=diagnose node coursera_manual_runner.js",
    "check": "node --check coursera_manual_runner.js",
    "install-browsers": "npx playwright install chromium"
  },
  "dependencies": {
    "playwright": "^1.61.1",
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^0.0.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
